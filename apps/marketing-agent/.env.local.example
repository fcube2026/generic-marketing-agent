# API base URL for the marketing agent portal.
# When this is not set the app auto-detects localhost (for local development)
# or falls back to https://api.example.com/api/v1 (for production).
#
# Set this when you want to point a locally-running marketing-agent at a
# specific API (e.g. staging) without running the API locally.
#
# Examples:
#   Staging:    NEXT_PUBLIC_API_URL=https://api.staging.example.com/api/v1
#   Production: NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
#   Local:      NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# NEXT_PUBLIC_API_URL=https://api.staging.example.com/api/v1

# ─── AI providers (server-side only — never prefix with NEXT_PUBLIC_) ───
# Used by the Next.js API routes /api/ai/chat and /api/ai/image.
# Both routes try the preferred provider first and automatically fail over
# to the other (OpenAI ↔ Google) on transient errors (401/403, 404, 429,
# 5xx, missing key). If both providers fail the route returns 502.
# OPENAI_API_KEY=sk-...
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_BASE_URL=                 # optional override for Azure OpenAI / proxies

# Google AI Studio (Gemini / Imagen).  Get a key at https://aistudio.google.com/apikey
# Used by /api/ai/image and /api/ai/chat. Acts as the failover partner for
# OpenAI — if OpenAI fails (or vice versa) the route automatically retries
# with this provider.
# GOOGLE_AI_API_KEY=AIza...
# Default is Gemini 2.5 Flash Image ("Nano Banana") — works on free AI Studio keys:
# GOOGLE_AI_IMAGE_MODEL=gemini-2.5-flash-image
# Or use Imagen 3 (requires a billing-enabled GCP project):
# GOOGLE_AI_IMAGE_MODEL=imagen-3.0-generate-002
# GOOGLE_AI_TEXT_MODEL=gemini-1.5-flash
# GOOGLE_AI_BASE_URL=              # optional override (e.g. proxy / regional endpoint)

# Preferred image provider tried first ("openai" | "google"). The other
# provider is used automatically as failover; this only controls ordering.
# AI_IMAGE_PROVIDER=openai

# Preferred text/chat provider tried first ("openai" | "google"). The other
# provider is used automatically as failover; this only controls ordering.
# AI_TEXT_PROVIDER=openai

# Skip the upstream JWT-validation hop on the AI routes (dev/test only).
# MARKETING_AGENT_SKIP_AUTH=true

# ─── Pluggable data source ───────────────────────────────────────────────
# When unset, the marketing-agent serves /api/backend/* from the in-memory
# mock store. To make the dashboard render data from your own database
# instead, configure a connection from the in-app Settings → Data Source
# page (recommended) — the connection string is encrypted at rest with
# the secret below and never exposed to the browser.
#
# Required if you plan to connect a database from the Settings UI:
#   MARKETING_AGENT_SECRET=<random 32+ char string used to encrypt the DSN>
#
# Optional — directory used to persist the encrypted DSN + mappings.
# Defaults to "<cwd>/.marketing-agent". Use a writable, persistent volume
# in production deployments.
#   MARKETING_AGENT_CONFIG_DIR=/var/lib/marketing-agent

# ─── Direct data-source selection (DATA_SOURCE) ─────────────────────────
# Skip the Settings UI and pick an adapter at boot via env vars.
#
#   DATA_SOURCE=memory   (default — in-process mock; resets on restart)
#   DATA_SOURCE=prisma   (generic AgentResource table only — no fcube data)
#   DATA_SOURCE=fcube    (read fcube clinical tables + persist marketing
#                         artefacts in the AgentResource table)
#   DATA_SOURCE=rest     (proxy to AGENT_REST_BASE_URL)
#
# When DATA_SOURCE=fcube the dashboard surfaces these fcube tables read-only:
#   - users           ← User
#   - patients        ← PatientProfile (joined with User)
#   - providers       ← ProviderProfile (joined with User)
#   - bookings        ← Booking
#   - pharmacy-orders ← PharmacyOrder
# and computes live values for these KPIs:
#   monthly-active-customers, weekly-transactions, active-providers,
#   new-signups, onboarding-completion, d7-retention, d30-retention,
#   d90-retention.
# All other resources (campaigns, experiments, content-items, seo-pages,
# keyword-clusters, lifecycle-flows, plan-items) are stored in the
# `agent_resources` table and remain writable.
#
# Before first boot, generate the Prisma client once:
#   pnpm --filter @curex24/database db:generate
# and apply the migration that creates `agent_resources`:
#   pnpm --filter @curex24/database db:migrate:deploy
#
# Use a least-privilege Postgres role with SELECT on the clinical tables
# and ALL on `agent_resources` only. Never point the marketing-agent at
# the `postgres` superuser URL.
#
# DATA_SOURCE=fcube
# DATABASE_URL=postgresql://marketing_agent:<password>@<host>:6543/postgres?pgbouncer=true&sslmode=require
