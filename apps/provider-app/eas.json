{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL": "http://localhost:3000/api/v1"
      }
    },
    "staging": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://api.staging.curex24.com/api/v1",
        "EXPO_PUBLIC_SUPABASE_URL": "https://ksmufpryzrozpqdejlwa.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "staging-anon-key"
      },
      "channel": "staging"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://api.curex24.com/api/v1",
        "EXPO_PUBLIC_SUPABASE_URL": "https://PROD_PROJECT_REF.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "production-anon-key"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
