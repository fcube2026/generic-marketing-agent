{
  "expo": {
    "name": "Curex24",
    "slug": "curex24",
    "version": "1.0.0",
    "sdkVersion": "51.0.0",
    "runtimeVersion": "51.0.0",
    "updates": {
      "url": "https://u.expo.dev/32ba7225-63f2-4092-95e5-1e24cb77d6a2"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0D9488"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.curex24.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Curex24 needs camera access for video consultations.",
        "NSMicrophoneUsageDescription": "Curex24 needs microphone access for audio during video consultations.",
        "NSLocationWhenInUseUsageDescription": "Curex24 needs your location to track your provider's arrival for home-visit bookings."
      }
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0D9488"
      },
      "package": "com.curex24.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    }
  }
}
