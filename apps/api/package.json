{
  "name": "@curex24/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "node ../../node_modules/@nestjs/cli/bin/nest.js build",
    "dev": "node ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start": "node dist/main",
    "start:dev": "node ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "node ../../node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "format:check": "prettier --check \"{src,apps,libs,test}/**/*.ts\"",
    "format:fix": "prettier --write \"{src,apps,libs,test}/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js --forceExit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/terminus": "^10.3.0",
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^30.3.0",
    "prettier": "^3.3.0",
    "prisma": "^5.15.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
