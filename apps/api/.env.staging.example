# ──────────────────────────────────────────────────────────────
# Curex24 API — STAGING Environment Variables
# ⚠️  NEVER use production keys here. Staging is fully isolated.
# ──────────────────────────────────────────────────────────────

APP_ENV=staging
NODE_ENV=production
PORT=3000

# ── Database — STAGING Supabase Project ────────────────────────
# Use Railway-provisioned PostgreSQL or a separate Supabase staging project
DATABASE_URL="postgresql://postgres.ksmufpryzrozpqdejlwa:Curex24%23%242026@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.ksmufpryzrozpqdejlwa:Curex24%23%242026@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=staging-jwt-secret-change-this-to-a-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@staging.curex24.com
ADMIN_PASSWORD=staging-admin-password
MARKETING_EMAIL=marketing@staging.curex24.com
MARKETING_PASSWORD=staging-marketing-password

# ── CORS — staging domains only ───────────────────────────────
CORS_ORIGINS=https://staging.curex24.com,https://admin.staging.curex24.com,https://app.staging.curex24.com,https://curex24-admin.vercel.app

# ── Supabase — STAGING project ─────────────────────────────────
SUPABASE_URL=https://ksmufpryzrozpqdejlwa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=staging-service-role-key

# ── Railway ────────────────────────────────────────────────────
# RAILWAY_STATIC_URL is auto-set by Railway. Custom domain: api.staging.curex24.com

# ── NMC Doctor Verification ────────────────────────────────────
# Use "mock" for staging tests, or point to a live provider for full integration testing.
NMC_API_PROVIDER=mock
# NMC_API_URL=https://api.surepass.io/api/v1/nmc/verify
# NMC_API_KEY=your-staging-nmc-api-key
