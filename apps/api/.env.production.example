# ──────────────────────────────────────────────────────────────
# Curex24 API — PRODUCTION Environment Variables
# ⚠️  Keep these secrets secure. Never commit real values.
# ──────────────────────────────────────────────────────────────

APP_ENV=production
NODE_ENV=production
PORT=3000

# ── Database — PRODUCTION Supabase Project ─────────────────────
DATABASE_URL="postgresql://postgres.PROD_PROJECT_REF:PROD_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PROD_DB_PASSWORD@db.PROD_PROJECT_REF.supabase.co:5432/postgres"

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=production-jwt-secret-use-a-strong-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@curex24.com
ADMIN_PASSWORD=strong-production-admin-password

# ── CORS — production domains only ────────────────────────────
CORS_ORIGINS=https://curex24.com,https://app.curex24.com,https://admin.curex24.com

# ── Supabase — PRODUCTION project ─────────────────────────────
SUPABASE_URL=https://PROD_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=production-service-role-key

# ── Railway ────────────────────────────────────────────────────
# Custom domain: api.curex24.com
