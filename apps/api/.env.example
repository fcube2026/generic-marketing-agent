# ──────────────────────────────────────────────────────────────
# Curex24 API — Environment Variables
# Copy to .env and fill in values for your environment
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
# APP_ENV controls application behavior: development | staging | production
APP_ENV=development
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL / Supabase) ───────────────────────────
# Local development (default):
DATABASE_URL="postgresql://curex24:curex24password@localhost:5432/curex24?schema=public"
# Direct (non-pooled) connection string — used ONLY for Prisma migrations
# Local development (default): same as DATABASE_URL
DIRECT_URL="postgresql://curex24:curex24password@localhost:5432/curex24?schema=public"

# For Supabase (staging/production): use the Session Pooler URL from Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres.<YOUR_PROJECT_ID>:<DB_PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:<DB_PASSWORD>@db.<YOUR_PROJECT_ID>.supabase.co:5432/postgres

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=curex24-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@curex24.com
ADMIN_PASSWORD=admin123
MARKETING_EMAIL=marketing@curex24.com
MARKETING_PASSWORD=marketing123

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for development only.
# staging example: https://staging.curex24.com,https://admin.staging.curex24.com
CORS_ORIGINS=*

# ── Supabase (if using Supabase client in backend) ─────────────
# SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NMC Doctor Verification ────────────────────────────────────
# Provider: mock | surepass | decentro | idfy
# Use "mock" for local development — always returns a successful verified result.
NMC_API_PROVIDER=mock
# NMC_API_URL=https://api.surepass.io/api/v1/nmc/verify
# NMC_API_KEY=your-nmc-api-key

# ── 100ms Video Consultation ───────────────────────────────────
# Obtain from https://dashboard.100ms.live → Developer → App Access Key & App Secret
# HMS_APP_ACCESS_KEY and HMS_APP_SECRET are required for video room creation and token generation.
# HMS_TEMPLATE_ID is optional — leave unset to use the account's default template.
HMS_APP_ACCESS_KEY=69e75485f8e80a674997e655
HMS_APP_SECRET=JIh59ew4yMB36vOWY8DLhhAJ1OX3H1496v3aST8fb93qRo3H9KDod_kZFB9WJDDb4lKiw7iITwprSJ0IuSfJsR-PbPHvCQK6N9r9gJg_YMKfyBOQ1VLxhV7m3XDkZALMwxnAITeuKRiCpr2RfLfwxZLJ_24N1Oy9h_EmQfQwmUs=
HMS_TEMPLATE_ID=69e7566497aa609b0288ad86
# Set VIDEO_MOCK_MODE=true to skip real 100ms API calls (useful for local dev without credentials).
# The mobile app detects mock tokens and renders a simulated call UI automatically.
VIDEO_MOCK_MODE=false

# ── Redis (BullMQ / Background Jobs) ─────────────────────────
# Required for background job processing. Leave unset to disable queues.
# REDIS_URL=redis://localhost:6379

# ── Pharmacy Background Jobs ──────────────────────────────────
# How often to poll pharmacy order statuses (ms). Default: 300000 (5 min)
# PHARMACY_STATUS_POLL_INTERVAL_MS=300000
# How many days before refill date to send the first reminder. Default: 3
# PHARMACY_REFILL_REMINDER_DAYS_BEFORE=3
