# Pooled connection string (session pooler) — used by the running API
# For Supabase: use the Session Pooler URL from Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Direct (non-pooled) connection string — used ONLY for Prisma migrations
# For Supabase: use the Direct Connection URL from Settings → Database → Connection string
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
JWT_SECRET=curex24-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development
PORT=3000
