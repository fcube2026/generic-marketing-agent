{
  "name": "curex24",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @curex24/database db:generate",
    "db:migrate": "pnpm --filter @curex24/database db:migrate",
    "db:studio": "pnpm --filter @curex24/database db:studio",
    "typecheck": "turbo lint",
    "format:check": "turbo format:check",
    "ci": "turbo lint build test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "prettier": "3.8.1",
    "turbo": "^2.1.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "lint-staged": {
    "apps/api/{src,apps,libs,test}/**/*.ts": [
      "prettier --write --config apps/api/.prettierrc"
    ]
  }
}
