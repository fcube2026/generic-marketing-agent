{
  "name": "curex24",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @curex24/database db:generate",
    "db:migrate": "pnpm --filter @curex24/database db:migrate",
    "db:studio": "pnpm --filter @curex24/database db:studio",
    "typecheck": "turbo lint",
    "format:check": "turbo format:check",
    "ci": "turbo lint build test"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.4.5",
    "@types/node": "^20.14.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
