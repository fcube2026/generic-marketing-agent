# ---- LLM provider (OpenAI-compatible) ----
# Leave empty to run in DRY-RUN mode (templated outputs, no network calls).
LLM_API_KEY=
# Default points to OpenAI. Works with any OpenAI-compatible endpoint
# (Azure OpenAI, OpenRouter, Together, Groq, Ollama via /v1, vLLM, etc.).
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_MS=60000

# ---- Agent behavior ----
# Where the agent persists business profile, strategy, plans, assets.
CMO_AGENT_DATA_DIR=.cmo-agent
# Set to "true" to require human confirmation before saving new artifacts.
CMO_AGENT_HUMAN_REVIEW=false
