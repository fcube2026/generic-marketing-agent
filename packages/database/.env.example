# ──────────────────────────────────────────────────────────────
# Curex24 Database — Environment Variables
# Used by Prisma CLI and the API at runtime.
# ──────────────────────────────────────────────────────────────

# ── Local Development ──────────────────────────────────────────
DATABASE_URL="postgresql://curex24:curex24password@localhost:5432/curex24?schema=public"
DIRECT_URL="postgresql://curex24:curex24password@localhost:5432/curex24?schema=public"

# ── Supabase (staging) ────────────────────────────────────────
# DATABASE_URL=postgresql://postgres.STAGING_PROJECT_REF:DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:DB_PASSWORD@db.STAGING_PROJECT_REF.supabase.co:5432/postgres

# ── Supabase (production) ─────────────────────────────────────
# DATABASE_URL=postgresql://postgres.PROD_PROJECT_REF:DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:DB_PASSWORD@db.PROD_PROJECT_REF.supabase.co:5432/postgres
