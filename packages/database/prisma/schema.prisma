generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                          String                  @id @default(cuid())
  phone                       String                  @unique
  email                       String?                 @unique
  passwordHash                String?
  isActive                    Boolean                 @default(true)
  role                        Role                    @default(PATIENT)
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  addresses                   Address[]
  adminActions                AdminAction[]           @relation("AdminActions")
  auditLogs                   AuditLog[]
  deviceTokens                DeviceToken[]
  notifications               Notification[]
  notificationLogs            NotificationLog[]
  notificationPreference      NotificationPreference?
  otpVerifications            OtpVerification[]
  patientProfile              PatientProfile?
  providerProfile             ProviderProfile?
  questionnaireResponse       QuestionnaireResponse?
  uploadedPrescriptions       UploadedPrescription[]
  assignedPrescriptionReviews UploadedPrescription[]  @relation("AssignedPrescriptionReviews")
  passwordResetTokens         PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model PatientProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  name             String
  dateOfBirth      DateTime?
  gender           String?
  emergencyContact String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  bookings         Booking[]
  pharmacyOrders   PharmacyOrder[]
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model ProviderProfile {
  id                               String   @id @default(cuid())
  userId                           String   @unique
  name                             String
  bio                              String?
  specialization                   String
  contactInfo                      String   @default("")
  clinicAddress                    String   @default("")
  licenseNumber                    String?
  isVerified                       Boolean  @default(false)
  isActive                         Boolean  @default(true)
  homeVisitEnabled                 Boolean  @default(false)
  doctorPlaceVisitEnabled          Boolean  @default(false)
  serviceRadius                    Float    @default(10)
  consultationFeeHomeVisit         Float    @default(0)
  consultationFeeDoctorPlace       Float    @default(0)
  currentLat                       Float?
  currentLng                       Float?
  isAvailable                      Boolean  @default(false)
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
  videoConsultationEnabled         Boolean  @default(false) // ✅ restore
  consultationFeeVideoConsultation Float    @default(0)

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenses          ProviderLicense[]
  providerServices  ProviderService[]
  availabilitySlots AvailabilitySlot[]
  bookings          Booking[]
  doctorKits        DoctorKit[]
  payouts           Payout[]
  verificationLogs  DoctorVerificationLog[]

  @@map("provider_profiles")
}

model ProviderLicense {
  id              String        @id @default(cuid())
  providerId      String
  type            String
  documentUrl     String
  status          LicenseStatus @default(PENDING)
  rejectionReason String?
  expiresAt       DateTime?
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())

  nmcRegistrationNumber String?
  stateCouncil          String?
  yearOfAdmission       String?
  verificationSource    String?
  verificationAttempts  Int       @default(0)
  lastAttemptAt         DateTime?
  nextReverificationDue DateTime?

  provider         ProviderProfile         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  verificationLogs DoctorVerificationLog[]

  @@map("provider_licenses")
}

model DoctorVerificationLog {
  id                 String   @id @default(cuid())
  providerId         String
  licenseId          String?
  registrationNumber String
  stateCouncil       String
  verificationSource String
  status             String
  rawRequest         Json?
  rawResponse        Json?
  errorCode          String?
  createdAt          DateTime @default(now())

  provider ProviderProfile  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  // SetNull (not Cascade) so audit logs are retained when a license record is deleted
  license  ProviderLicense? @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  @@index([providerId])
  @@index([createdAt])
  @@index([providerId, createdAt])
  @@map("doctor_verification_logs")
}

model ServiceCategory {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  description      String?
  iconUrl          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bookings         Booking[]
  providerServices ProviderService[]

  @@map("service_categories")
}

model ProviderService {
  id                String          @id @default(cuid())
  providerId        String
  serviceCategoryId String
  createdAt         DateTime        @default(now())
  provider          ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  @@unique([providerId, serviceCategoryId])
  @@map("provider_services")
}

model AvailabilitySlot {
  id         String          @id @default(cuid())
  providerId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("availability_slots")
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String
  addressLine String
  city        String
  state       String
  pincode     String
  lat         Float?
  lng         Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  pharmacyOrders PharmacyOrder[] // ✅ ADD THIS LINE

  @@map("addresses")
}

model Booking {
  id                  String                 @id @default(cuid())
  patientId           String
  providerId          String
  serviceCategoryId   String
  addressId           String?
  mode                BookingMode
  status              BookingStatus          @default(REQUESTED)
  scheduledAt         DateTime
  symptoms            String?
  totalFee            Float
  paymentStatus       PaymentStatus          @default(PENDING)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  statusHistory       BookingStatusHistory[]
  address             Address?               @relation(fields: [addressId], references: [id])
  patient             PatientProfile         @relation(fields: [patientId], references: [id])
  provider            ProviderProfile        @relation(fields: [providerId], references: [id])
  serviceCategory     ServiceCategory        @relation(fields: [serviceCategoryId], references: [id])
  consultationSummary ConsultationSummary?
  diagnosticRequests  DiagnosticRequest[]
  payment             Payment?
  payout              Payout?
  providerLocations   ProviderLocation[]
  referrals           Referral[]
  pharmacyOrders      PharmacyOrder[]
  videoSession        VideoSession?

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model BookingStatusHistory {
  id        String        @id @default(cuid())
  bookingId String
  status    BookingStatus
  changedAt DateTime      @default(now())
  changedBy String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_status_history")
}

model ConsultationSummary {
  id                     String         @id @default(cuid())
  bookingId              String         @unique
  symptoms               String?
  observations           String?
  diagnosis              String?
  medicinesAdvised       Json?
  nextSteps              String?
  followUpRecommendation String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  booking                Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  prescriptions          Prescription[]

  @@map("consultation_summaries")
}

model Prescription {
  id                    String              @id @default(cuid())
  consultationSummaryId String
  details               String?
  fileUrl               String?
  createdAt             DateTime            @default(now())
  consultationSummary   ConsultationSummary @relation(fields: [consultationSummaryId], references: [id], onDelete: Cascade)
  pharmacyOrders        PharmacyOrder[]

  @@map("prescriptions")
}

model DiagnosticRequest {
  id          String           @id @default(cuid())
  bookingId   String
  testType    String
  notes       String?
  status      DiagnosticStatus @default(REQUESTED)
  scheduledAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  booking     Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  labResults  LabResult[]

  @@index([bookingId])
  @@index([status])
  @@map("diagnostic_requests")
}

model LabResult {
  id                  String            @id @default(cuid())
  diagnosticRequestId String
  resultFileUrl       String?
  notes               String?
  uploadedAt          DateTime          @default(now())
  diagnosticRequest   DiagnosticRequest @relation(fields: [diagnosticRequestId], references: [id], onDelete: Cascade)

  @@map("lab_results")
}

model Referral {
  id             String         @id @default(cuid())
  bookingId      String
  specialistType String
  notes          String?
  status         ReferralStatus @default(RECOMMENDED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("referrals")
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  amount        Float
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Payout {
  id          String          @id @default(cuid())
  providerId  String
  bookingId   String          @unique
  amount      Float
  status      PayoutStatus    @default(PENDING)
  processedAt DateTime?
  createdAt   DateTime        @default(now())
  booking     Booking         @relation(fields: [bookingId], references: [id])
  provider    ProviderProfile @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([status])
  @@map("payouts")
}

model DoctorKit {
  id          String          @id @default(cuid())
  providerId  String
  name        String
  description String?
  createdAt   DateTime        @default(now())
  items       DoctorKitItem[]
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("doctor_kits")
}

model DoctorKitItem {
  id          String    @id @default(cuid())
  doctorKitId String
  itemName    String
  quantity    Int
  unit        String
  doctorKit   DoctorKit @relation(fields: [doctorKitId], references: [id], onDelete: Cascade)

  @@map("doctor_kit_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("audit_logs")
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String
  targetType String
  notes      String?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminActions", fields: [adminId], references: [id])

  @@map("admin_actions")
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([phone])
  @@map("otp_verifications")
}

model ProviderLocation {
  id         String   @id @default(cuid())
  bookingId  String
  lat        Float
  lng        Float
  recordedAt DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, recordedAt(sort: Desc)])
  @@map("provider_locations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model QuestionnaireResponse {
  id                    String   @id @default(cuid())
  userId                String   @unique
  primarySpecialization String?
  highestQualification  String?
  licensedToPractice    String?
  clinicalExperience    String?
  servicesProvided      String?
  patientGroups         String?
  preferredSchedule     String?
  availableTimes        String?
  travelDistance        String?
  mobileAppComfort      String?
  onlineConsultation    String?
  medicalEquipment      String?
  preferredPayment      String?
  handleEmergency       String?
  platformExpectations  String?
  followGuidelines      String?
  homeVisitComfort      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("questionnaire_responses")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String // "ios" | "android" | "web"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model NotificationPreference {
  id               String  @id @default(cuid())
  userId           String  @unique
  pushEnabled      Boolean @default(true)
  smsEnabled       Boolean @default(true)
  whatsappEnabled  Boolean @default(true)
  emailEnabled     Boolean @default(false)
  // Granular preferences for different notification types
  bookingUpdates   Boolean @default(true)
  paymentUpdates   Boolean @default(true)
  reminderEnabled  Boolean @default(true)
  marketingEnabled Boolean @default(false)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationLog {
  id                String                     @id @default(cuid())
  userId            String
  eventType         String
  channel           NotificationChannel
  status            NotificationDeliveryStatus @default(PENDING)
  providerMessageId String?
  idempotencyKey    String?
  metadata          Json?
  errorMessage      String?
  retryCount        Int                        @default(0)
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([idempotencyKey])
  @@index([channel, status])
  @@index([createdAt])
  @@map("notification_logs")
}

enum NotificationChannel {
  PUSH
  SMS
  WHATSAPP
  EMAIL
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  FALLBACK_TRIGGERED
}

enum Role {
  PATIENT
  PROVIDER
  ADMIN
  PHARMACIST
  MARKETING_AGENT
}

enum BookingMode {
  HOME_VISIT
  DOCTOR_PLACE
  VIDEO_CONSULTATION // ✅ restore (prevents deletion)
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  DECLINED
  ON_THE_WAY
  ARRIVED
  IN_PROGRESS
  COMPLETED
  SUMMARY_SUBMITTED
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DiagnosticStatus {
  REQUESTED
  SCHEDULED
  COLLECTED
  RESULTED
}

enum ReferralStatus {
  RECOMMENDED
  BOOKED
  COMPLETED
}

enum PayoutStatus {
  PENDING
  PROCESSED
}

enum LicenseStatus {
  PENDING
  APPROVED
  REJECTED
}

// =======================
// PHARMACY MODELS (UPDATED)
// =======================
model PharmacyPartner {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  displayName String
  description String?
  logoUrl     String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  apiBaseUrl  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders PharmacyOrder[]

  @@map("pharmacy_partners")
}

model PharmacyOrder {
  id                     String              @id @default(cuid())
  orderNumber            String              @unique
  patientProfileId       String
  bookingId              String?
  prescriptionId         String?
  uploadedPrescriptionId String?
  pharmacyPartnerId      String
  partnerOrderId         String?
  deliveryAddressId      String
  prescriptionImageUrl   String?
  subtotal               Float
  deliveryFee            Float               @default(0)
  discount               Float               @default(0)
  totalAmount            Float
  status                 PharmacyOrderStatus @default(PENDING)
  estimatedDeliveryAt    DateTime?
  deliveredAt            DateTime?
  notes                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  items                PharmacyOrderItem[]
  statusHistory        PharmacyOrderStatusHistory[]
  booking              Booking?                     @relation(fields: [bookingId], references: [id])
  deliveryAddress      Address                      @relation(fields: [deliveryAddressId], references: [id])
  patientProfile       PatientProfile               @relation(fields: [patientProfileId], references: [id])
  pharmacyPartner      PharmacyPartner              @relation(fields: [pharmacyPartnerId], references: [id])
  prescription         Prescription?                @relation(fields: [prescriptionId], references: [id])
  uploadedPrescription UploadedPrescription?        @relation(fields: [uploadedPrescriptionId], references: [id])

  @@index([patientProfileId])
  @@index([pharmacyPartnerId])
  @@index([uploadedPrescriptionId])
  @@index([status])
  @@index([createdAt])
  @@map("pharmacy_orders")
}

model PharmacyOrderItem {
  id              String  @id @default(cuid())
  pharmacyOrderId String
  medicineName    String
  medicineCode    String?
  dosage          String?
  instructions    String?
  isSubstitute    Boolean @default(false)
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  pharmacyOrder PharmacyOrder @relation(fields: [pharmacyOrderId], references: [id], onDelete: Cascade)

  @@map("pharmacy_order_items")
}

model PharmacyOrderStatusHistory {
  id              String              @id @default(cuid())
  pharmacyOrderId String
  status          PharmacyOrderStatus
  source          String? // e.g. "webhook:mock", "webhook:partner-xyz", "manual"
  timestamp       DateTime            @default(now())

  pharmacyOrder PharmacyOrder @relation(fields: [pharmacyOrderId], references: [id], onDelete: Cascade)

  @@unique([pharmacyOrderId, status])
  @@index([pharmacyOrderId])
  @@index([timestamp])
  @@map("pharmacy_order_status_history")
}

// =======================
// UPDATED ENUM
// =======================

enum PharmacyOrderStatus {
  PENDING
  PRESCRIPTION_REVIEW
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

// =======================
// DOCTOR ONBOARDING
// =======================

model doctor_onboarding_questionnaire {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  specialization String?
  qualification  String?
  experience     String?
  hospital       String?
  bio            String?
  home_visits    String?

  services          String[]
  patient_groups    String[]
  medical_equipment String[]

  emergency_cases  String?
  working_schedule String?
  time_slots       String[]

  travel_distance      String?
  payment_preference   String?
  app_comfort          String?
  online_consultations String?

  platform_expectations String[]
  guidelines_agreement  String?

  @@map("doctor_onboarding_questionnaire")
}

enum VideoSessionStatus {
  CREATED
  WAITING
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
}

model VideoSession {
  id            String             @id @default(cuid())
  bookingId     String?            @unique
  roomId        String             @unique
  sessionToken  String?
  status        VideoSessionStatus @default(CREATED)
  startedAt     DateTime?
  endedAt       DateTime?
  duration      Int?
  creatorUserId String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  booking       Booking?           @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
  @@index([creatorUserId])
  @@map("video_sessions")
}

// =======================
// PRESCRIPTION UPLOAD & VERIFICATION
// =======================

enum PrescriptionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  REUPLOAD_REQUIRED
}

enum PrescriptionReviewAction {
  APPROVED
  REJECTED
  REUPLOAD
}

model UploadedPrescription {
  id                 String             @id @default(cuid())
  userId             String
  filePath           String
  status             PrescriptionStatus @default(PENDING_REVIEW)
  assignedReviewerId String?
  assignedAt         DateTime?
  reviewedBy         String?
  reviewNotes        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedReviewer User?                   @relation("AssignedPrescriptionReviews", fields: [assignedReviewerId], references: [id], onDelete: SetNull)
  reviewLogs       PrescriptionReviewLog[]
  pharmacyOrders   PharmacyOrder[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedReviewerId])
  @@map("uploaded_prescriptions")
}

model PrescriptionReviewLog {
  id             String                   @id @default(cuid())
  prescriptionId String
  action         PrescriptionReviewAction
  performedBy    String
  notes          String?
  createdAt      DateTime                 @default(now())

  prescription UploadedPrescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_review_logs")
}

// =======================
// MARKETING MODELS
// =======================

model MarketingBusinessProfile {
  id                      String   @id @default(cuid())
  primaryGrowthFocus      String   @default("both") // 'patients' | 'providers' | 'both'
  biggestBottleneck       String   @default("demand") // 'supply' | 'demand' | 'activation'
  monthlyBudget           Int      @default(0)
  allocatedBudget         Int      @default(0)
  targetCities            String[] @default([])
  bestPerforming          String   @default("")
  topPatientPersona       String   @default("")
  topReasonPatientChooses String   @default("")
  topReasonProviderJoins  String   @default("")
  competitors             String[] @default([])
  founderLedBrand         Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("marketing_business_profiles")
}

model MarketingCampaign {
  id          String    @id @default(cuid())
  name        String
  objective   String
  channel     String
  audience    String
  budget      String
  duration    String
  kpi         String
  status      String    @default("planned") // 'active' | 'planned' | 'completed' | 'paused'
  headline    String[]  @default([])
  description String[]  @default([])
  spend       Float     @default(0)
  impressions Int       @default(0)
  conversions Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@map("marketing_campaigns")
}

model MarketingExperiment {
  id         String   @id @default(cuid())
  name       String
  hypothesis String
  channel    String
  control    String
  variant    String
  metric     String
  startDate  String
  endDate    String
  result     String?
  winner     String? // 'control' | 'variant' | 'no-difference'
  status     String   @default("planned") // 'running' | 'completed' | 'planned' | 'paused'
  lift       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@map("marketing_experiments")
}

model MarketingContentItem {
  id          String    @id @default(cuid())
  week        Int
  day         String
  platform    String
  pillar      String // 'patient-education' | 'provider-spotlight' | 'product-education' | 'social-proof' | 'local-health'
  title       String
  format      String
  status      String    @default("planned") // 'planned' | 'in-progress' | 'ready' | 'published'
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([week])
  @@index([status])
  @@map("marketing_content_items")
}

model MarketingSeoPage {
  id            String   @id @default(cuid())
  url           String   @unique
  type          String // 'city-specialty' | 'condition' | 'blog' | 'comparison'
  title         String
  status        String   @default("planned") // 'live' | 'in-progress' | 'planned'
  targetKeyword String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("marketing_seo_pages")
}

model MarketingKeywordCluster {
  id        String   @id @default(cuid())
  cluster   String
  type      String // 'transactional' | 'informational' | 'comparison' | 'provider-side'
  priority  String // 'high' | 'medium' | 'low'
  keywords  Json     @default("[]") // Array<{ keyword, volume, difficulty }>
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketing_keyword_clusters")
}

model MarketingLifecycleFlow {
  id        String                   @id @default(cuid())
  name      String
  segment   String // 'patient' | 'provider'
  trigger   String
  status    String                   @default("draft") // 'active' | 'draft' | 'paused'
  steps     MarketingLifecycleStep[]
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@map("marketing_lifecycle_flows")
}

model MarketingLifecycleStep {
  id      String @id @default(cuid())
  flowId  String
  day     Int
  channel String
  message String
  goal    String
  order   Int    @default(0)

  flow MarketingLifecycleFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@map("marketing_lifecycle_steps")
}

model MarketingPlanItem {
  id        String   @id @default(cuid())
  phase     String // '1-30' | '31-60' | '61-90'
  category  String
  task      String
  owner     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phase])
  @@map("marketing_plan_items")
}

model MarketingIntakeResponse {
  id         String   @id @default(cuid())
  questionId String   @unique
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("marketing_intake_responses")
}
