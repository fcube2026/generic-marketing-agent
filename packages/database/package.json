{
  "name": "@curex24/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "node --max-old-space-size=4096 ../../node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "db:migrate": "node --max-old-space-size=4096 ../../node_modules/prisma/build/index.js migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "node --max-old-space-size=4096 ../../node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma",
    "db:studio": "node --max-old-space-size=4096 ../../node_modules/prisma/build/index.js studio --schema prisma/schema.prisma",
    "db:seed": "node ../../node_modules/ts-node/dist/bin.js prisma/seed.ts",
    "db:seed:staging": "node ../../node_modules/ts-node/dist/bin.js prisma/seed.ts && node ../../node_modules/ts-node/dist/bin.js prisma/seed-staging.ts",
    "db:reset": "echo '⚠️  WARNING: This drops ALL tables! Use only on local dev databases.' && node --max-old-space-size=4096 ../../node_modules/prisma/build/index.js migrate reset --schema prisma/schema.prisma",
    "lint": "node --max-old-space-size=4096 ../../node_modules/prisma/build/index.js validate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/node": "^20.14.2"
  },
  "prisma": {
    "seed": "node ../../node_modules/ts-node/dist/bin.js prisma/seed.ts"
  }
}
