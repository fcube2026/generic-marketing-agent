{
  "name": "@curex24/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Shared design tokens for curex24 apps. Source of truth lives in tokens/tokens.json (Tokens Studio / Figma Variables shape). Build emits CSS variables, JS/TS objects and d.ts typings to dist/.",
  "main": "dist/tokens.js",
  "types": "dist/tokens.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.js": "./dist/tokens.js",
    "./tokens.d.ts": "./dist/tokens.d.ts",
    "./tokens.json": "./tokens/tokens.json"
  },
  "files": [
    "dist",
    "tokens",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-tokens.js",
    "lint": "node scripts/build-tokens.js --check"
  }
}
